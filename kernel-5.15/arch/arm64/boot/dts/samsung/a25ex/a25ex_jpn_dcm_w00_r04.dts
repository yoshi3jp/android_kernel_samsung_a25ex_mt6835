/* #include "../i2c-gpio.dtsi" */                    /* From i2c-gpio.py */
&pio {
       gpio_i2c_0_sda {
               gpio_i2c_0_sda_default: gpio_i2c_0_sda_default {
                       GPIO_CONFIG_PUD_DRV(AP,pio,24, FUNC_INPUT, PULL_NONE, DRV_LV1);
               };
       };
};

&pio {
       gpio_i2c_0_scl {
               gpio_i2c_0_scl_default: gpio_i2c_0_scl_default {
                       GPIO_CONFIG_PUD_DRV(AP,pio,23, FUNC_INPUT, PULL_NONE, DRV_LV1);
               };
       };
};

/ {
	fragment@model {
		target-path = "/";
	        __overlay__ {
			aliases {
				  i2c50 = "/i2c@50";
			};
			/* Software I2C */
			sw_i2c0: i2c@50 {
				cell-index = <50>;
				compatible = "i2c-gpio";
				gpios = <
					SEC_GPIO_REF(AP,pio,24) 0 /* SDA */
					SEC_GPIO_REF(AP,pio,23) 0 /* SCL */
					>;
				#i2c-gpio,delay-us = <2>;
				#address-cells = <1>;
				#size-cells = <0>;

				pinctrl-names = "default";
				pinctrl-0 = <
					&gpio_i2c_0_sda_default
					&gpio_i2c_0_scl_default
					>;

				status = "disabled";
			};
		};
	};
};


/* #include "../sec_thermistor-4.dtsi" */            /* From sec_thermistor.py */
/ {
	fragment@smd {
		target-path = "/";
		__overlay__ {
			samsung_mobile_device {
				sec_cf_thermistor: sec_thermistor@4 {
					compatible = "samsung,sec-thermistor";
					status = "okay";
					thermistor_name = "sec-cf-thermistor";
					id = <4>;

					io-channels = SEC_ADC(auxadc,2);
					io-channel-names = "cf_therm";
					io-channel-ranges;
				};
			};
		};
	};
};

/* #include "../sec_thermistor-2.dtsi" */            /* From sec_thermistor.py */
/ {
	fragment@smd {
		target-path = "/";
		__overlay__ {
			samsung_mobile_device {
				sec_lp_thermistor: sec_thermistor@2 {
					compatible = "samsung,sec-thermistor";
					status = "okay";
					thermistor_name = "sec-lp-thermistor";
					id = <2>;

					io-channels = SEC_ADC(auxadc,4);
					io-channel-names = "lp_therm";
					io-channel-ranges;
				};
			};
		};
	};
};

/* #include "../input_nt36xxx_spi.dtsi" */           /* From input_nt36xxx_spi.py */
/* NEED TO FIX IF YOU WANT USE THIS */

&pio {
	nt36xxx_tsp_intr_on: nt36xxx_tsp_intr_on {
		pins_cmd_dat {
			pinmux = <MTK_PINMUX(SEC_GPIO_NUM(AP,pio,14), 0)>;
			slew-rate = <0>;
			bias-disable;
		};
	};

	nt36xxx_tsp_intr_off: nt36xxx_tsp_intr_off {
		pins_cmd_dat {
			pinmux = <MTK_PINMUX(SEC_GPIO_NUM(AP,pio,14), 0)>;
			slew-rate = <0>;
			input-enable;
			bias-pull-down;
		};
	};
};
&pio {
	nt36xxx_tsp_reset_on: nt36xxx_tsp_reset_on {
		pins_cmd_dat{
			pinmux = <MTK_PINMUX(SEC_GPIO_NUM(AP,pio,9), 0)>;
			slew-rate = <1>;
			bias-disable;
			output-high;
		};
	};

	nt36xxx_tsp_reset_off: nt36xxx_tsp_reset_off {
		pins_cmd_dat{
			pinmux = <MTK_PINMUX(SEC_GPIO_NUM(AP,pio,9), 0)>;
			slew-rate = <1>;
			bias-disable;
			output-low;
		};
	};
};
&pio {
	nt36xxx_tsp_on_cs: nt36xxx_tsp_on_cs {
		pins_cmd_dat{
			pinmux = <MTK_PINMUX(SEC_GPIO_NUM(AP,pio,148), 1)>;
			bias-disable;
		};
	};
	nt36xxx_tsp_off_cs: nt36xxx_tsp_off_cs {
		pins_cmd_dat{
			pinmux = <MTK_PINMUX(SEC_GPIO_NUM(AP,pio,148), 0)>;
			slew-rate = <1>;
			bias-disable;
			output-low;
		};
	};
};
&pio {
	nt36xxx_tsp_on_clk: nt36xxx_tsp_on_clk {
		pins_cmd_dat{
			pinmux = <MTK_PINMUX(SEC_GPIO_NUM(AP,pio,147), 1)>;
			bias-disable;
		};
	};
	nt36xxx_tsp_off_clk: nt36xxx_tsp_off_clk {
		pins_cmd_dat{
			pinmux = <MTK_PINMUX(SEC_GPIO_NUM(AP,pio,147), 0)>;
			slew-rate = <1>;
			bias-disable;
			output-low;
		};
	};

	nt36xxx_tsp_on_mosi: nt36xxx_tsp_on_mosi {
		pins_cmd_dat{
			pinmux = <MTK_PINMUX(SEC_GPIO_NUM(AP,pio,149), 1)>;
			bias-disable;
		};
	};
	nt36xxx_tsp_off_mosi: nt36xxx_tsp_off_mosi {
		pins_cmd_dat{
			pinmux = <MTK_PINMUX(SEC_GPIO_NUM(AP,pio,149), 0)>;
			slew-rate = <1>;
			bias-disable;
			output-low;
		};
	};

	nt36xxx_tsp_on_miso: nt36xxx_tsp_on_miso {
		pins_cmd_dat{
			pinmux = <MTK_PINMUX(SEC_GPIO_NUM(AP,pio,150), 1)>;
			bias-disable;
		};
	};

	nt36xxx_tsp_off_miso: nt36xxx_tsp_off_miso {
		pins_cmd_dat{
			pinmux = <MTK_PINMUX(SEC_GPIO_NUM(AP,pio,150), 0)>;
			slew-rate = <0>;
			bias-pull-down;
			input-enable;
		};
	};

	nt36xxx_default_miso: nt36xxx_default_miso {
		pins_cmd_dat{
			pinmux = <MTK_PINMUX(SEC_GPIO_NUM(AP,pio,150), 0)>;
			slew-rate = <0>;
			bias-disable;
			output-low;
		};
	};
};

&spi7 {
	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;
	num-cs = <1>;
	tsp_novatek: novatek@0 {
		status = "okay";
		compatible = "nvt_ts_spi";
		reg = <0>; //Same as CS ID
		spi-max-frequency = <9600000>;

		pinctrl-names = "default", "on_state", "off_state";
		pinctrl-0 = <&nt36xxx_tsp_intr_on &nt36xxx_tsp_reset_on &nt36xxx_tsp_on_cs &nt36xxx_tsp_on_clk &nt36xxx_tsp_on_mosi &nt36xxx_tsp_on_miso>;
		pinctrl-1 = <&nt36xxx_tsp_intr_on &nt36xxx_tsp_reset_on &nt36xxx_tsp_on_cs &nt36xxx_tsp_on_clk &nt36xxx_tsp_on_mosi &nt36xxx_tsp_on_miso>;
		pinctrl-2 = <&nt36xxx_tsp_intr_off &nt36xxx_tsp_reset_off &nt36xxx_tsp_off_cs &nt36xxx_tsp_off_clk &nt36xxx_tsp_off_mosi &nt36xxx_tsp_off_miso>;

		novatek,reset-gpio = <SEC_GPIO_REF(AP,pio,9) 0x00>;
		novatek,irq-gpio = <SEC_GPIO_REF(AP,pio,14) 0x2002>;

		novatek,enable_sysinput_enabled;
	};
};
/* /home/dpi/qb5_8814/workspace/P4_1716/android/kernel/kmodule/input/sec_input_2024/touchscreen/novatek/nt36xxx_spi/dts/input-mtk-tsp-nt36xxx-spi.a25ex.dtsi */
&nt36xxx_tsp_on_cs {
	pins_cmd_dat{
		pinmux = <MTK_PINMUX(SEC_GPIO_NUM(AP,pio,148), 5)>;
		bias-disable;
	};
};

&nt36xxx_tsp_on_clk {
	pins_cmd_dat{
		pinmux = <MTK_PINMUX(SEC_GPIO_NUM(AP,pio,147), 5)>;
		bias-disable;
	};
};

&nt36xxx_tsp_on_mosi {
	pins_cmd_dat{
		pinmux = <MTK_PINMUX(SEC_GPIO_NUM(AP,pio,149), 5)>;
		bias-disable;
	};
};

&nt36xxx_tsp_on_miso {
	pins_cmd_dat{
		pinmux = <MTK_PINMUX(SEC_GPIO_NUM(AP,pio,150), 5)>;
		bias-disable;
	};
};

&tsp_novatek{
	status = "okay";
	compatible = "nvt_ts_spi";
	pinctrl-names = "default", "on_state", "off_state";
	pinctrl-0 = <&nt36xxx_tsp_intr_on &nt36xxx_tsp_off_cs &nt36xxx_tsp_off_clk &nt36xxx_tsp_off_mosi &nt36xxx_default_miso>;
	pinctrl-1 = <&nt36xxx_tsp_intr_on &nt36xxx_tsp_on_cs &nt36xxx_tsp_on_clk &nt36xxx_tsp_on_mosi &nt36xxx_tsp_on_miso>;
	pinctrl-2 = <&nt36xxx_tsp_intr_off &nt36xxx_tsp_off_cs &nt36xxx_tsp_off_clk &nt36xxx_tsp_off_mosi &nt36xxx_tsp_off_miso>;

	/delete-property/ novatek,reset-gpio;

	novatek,resolution = <1080 2408>;
	novatek,enable_settings_aot;
	novatek,support_ear_detect_mode;
	novatek,prox_lp_scan_enabled;
	novatek,enable_sysinput_enabled;
//	novatek,enable_glove_mode;

//	novatek,lcdid1-gpio = <&pio 165 0x0>;
//	novatek,lcdid2-gpio = <&pio 153 0x0>;
//	novatek,lcdid3-gpio = <&pio 150 0x0>;
	novatek,lcdid = <0>;
	novatek,lcdtype = <0x2b7240>;
	novatek,fw_name = "nt36672_a25ex_tianma.bin";
	novatek,fw_name_mp = "nt36672_a25ex_tianma_mp.bin";

	novatek,name_lcd_rst = "lcd_rst";
	novatek,name_lcd_vddi = "lcd_vddi";
	novatek,name_lcd_bl_en = "lcd_bl_en";
	novatek,name_lcd_vsp = "lcd_vsp";
	novatek,name_lcd_vsn = "lcd_vsn";

	/* 672A, 525B, 675, 526, 672C */
	novatek,swrst-n8-addr = <0x03F0FE>;
	novatek,spi-rd-fast-addr = <0x03F310>;

	/* MP */
	novatek,mp-support-dt;

	/* nt36672_a15ex_tianma.bin */
	novatek-mp-criteria-7261@0 {
		#address-cells = <1>;
		#size-cells = <0>;
		compatible = "novatek-mp-criteria-7261";

		/* sec cmd test config */
		open_test_spec = <(-511) 5120>;
		short_test_spec = <10000 14008>;
		diff_test_frame = <50>;
		fdm_x_num = <2>;
	};
};

/* /home/dpi/qb5_8814/workspace/P4_1716/android/kernel/kmodule/input/sec_input_2024/touchscreen/novatek/nt36xxx_spi/dts/input-mtk-tsp-nt36xxx-spi.a25ex.02.dtsi */
&tsp_novatek{
	novatek,resolution = <720 1600>;
	novatek,lcdtype = <0xAAF240>;
	novatek,fw_name = "nt36528a_a25ex_tianma.bin";
	novatek,fw_name_mp = "nt36528a_a25ex_tianma_mp.bin";
};

