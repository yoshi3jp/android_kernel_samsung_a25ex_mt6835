/* /home/dpi/qb5_8814/workspace/P4_1716/android/kernel/kmodule/sensors/isg5320a/dts/isg5320a_mtk.a25ex.dtsi */
&pio {
	grip_i2c: grip-i2c {
		pins_cmd0_dat {
			pinmux = <MTK_PINMUX(SEC_GPIO_NUM(AP,pio,142), 1)>;
			bias-pull-up;
		};
		pins_cmd1_dat {
			pinmux = <MTK_PINMUX(SEC_GPIO_NUM(AP,pio,141), 1)>;
			bias-pull-up;
		};
	};
};

&i2c7 {
	pinctrl-0 = <&grip_i2c>;
};
